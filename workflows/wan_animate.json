{
  "1": {
    "class_type": "WanVideoModelLoader",
    "_meta": { "title": "Wan2.2-Animate 14B (fp8 scaled — canonical; fits 48GB)" },
    "inputs": {
      "model": "Wan2_2-Animate-14B_fp8_e4m3fn_scaled_KJ.safetensors",
      "base_precision": "bf16",
      "quantization": "disabled",
      "load_device": "offload_device",
      "attention_mode": "sdpa"
    }
  },
  "2": {
    "class_type": "WanVideoVAELoader",
    "inputs": { "model_name": "wan_2.1_vae.safetensors", "precision": "bf16" }
  },
  "3": {
    "class_type": "CLIPVisionLoader",
    "inputs": { "clip_name": "clip_vision_h.safetensors" }
  },
  "8": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "inputs": {
      "model_name": "umt5-xxl-enc-bf16.safetensors",
      "precision": "bf16",
      "load_device": "offload_device",
      "quantization": "disabled"
    }
  },

  "5": {
    "class_type": "LoadImage",
    "_meta": { "title": "Reference Avatar" },
    "inputs": { "image": "/workspace/qi/input/reference_image.png" }
  },
  "6": {
    "class_type": "ImageScale",
    "_meta": { "title": "Scale reference to gen dims (pre-padded upstream)" },
    "inputs": {
      "image": ["5", 0],
      "upscale_method": "lanczos",
      "width": 1280,
      "height": 720,
      "crop": "disabled"
    }
  },
  "7": {
    "class_type": "WanVideoClipVisionEncode",
    "inputs": {
      "clip_vision": ["3", 0],
      "image_1": ["6", 0],
      "strength_1": 1.0,
      "strength_2": 1.0,
      "crop": "center",
      "combine_embeds": "average",
      "force_offload": true
    }
  },

  "10": {
    "class_type": "WanVideoTextEncode",
    "_meta": { "title": "Positive & Negative Prompts" },
    "inputs": {
      "positive_prompt": "A person performing slow, graceful Tai Chi movements, photorealistic, natural skin texture, soft cinematic studio lighting, smooth fluid motion, sharp focus, high detail.",
      "negative_prompt": "low quality, blurry, distorted, deformed limbs, extra fingers, extra limbs, mutated hands, watermark, text, logo, jpeg artifacts, oversaturated, flickering",
      "t5": ["8", 0],
      "force_offload": true,
      "device": "gpu"
    }
  },

  "11": {
    "class_type": "WanVideoLoraSelectMulti",
    "_meta": { "title": "Relight + Lightx2v distill LoRAs (canonical)" },
    "inputs": {
      "lora_0": "wan2.2_animate_14B_relight_lora_bf16.safetensors",
      "strength_0": 1.0,
      "lora_1": "Lightx2v/lightx2v_I2V_14B_480p_cfg_step_distill_rank64_bf16.safetensors",
      "strength_1": 1.2,
      "lora_2": "none",
      "strength_2": 1.0,
      "lora_3": "none",
      "strength_3": 1.0,
      "lora_4": "none",
      "strength_4": 1.0,
      "low_mem_load": false,
      "merge_loras": false
    }
  },
  "12": {
    "class_type": "WanVideoSetLoRAs",
    "inputs": { "model": ["1", 0], "lora": ["11", 0] }
  },
  "13": {
    "class_type": "WanVideoBlockSwap",
    "_meta": { "title": "Block Swap (0 = native; 80GB fits without offload)" },
    "inputs": {
      "blocks_to_swap": 0,
      "offload_img_emb": false,
      "offload_txt_emb": false,
      "use_non_blocking": true,
      "vace_blocks_to_swap": 0
    }
  },
  "14": {
    "class_type": "WanVideoSetBlockSwap",
    "inputs": { "model": ["12", 0], "block_swap_args": ["13", 0] }
  },

  "20": {
    "class_type": "VHS_LoadImages",
    "_meta": { "title": "Driving Video Frames" },
    "inputs": {
      "directory": "/workspace/qi/output/renders",
      "image_load_cap": 81,
      "skip_first_images": 0,
      "select_every_nth": 1
    }
  },
  "21": {
    "class_type": "OnnxDetectionModelLoader",
    "_meta": { "title": "YOLOv10m + ViTPose-H (official pose stack)" },
    "inputs": {
      "vitpose_model": "vitpose_h_wholebody_model.onnx",
      "yolo_model": "yolov10m.onnx",
      "onnx_device": "CUDAExecutionProvider"
    }
  },
  "22": {
    "class_type": "PoseAndFaceDetection",
    "_meta": { "title": "Whole-body pose + face crops (ViTPose-H, direct — no retarget)" },
    "inputs": {
      "model": ["21", 0],
      "images": ["20", 0],
      "width": 1280,
      "height": 720
    }
  },
  "23": {
    "class_type": "DrawViTPose",
    "_meta": { "title": "Render pose skeleton images" },
    "inputs": {
      "pose_data": ["22", 0],
      "width": 1280,
      "height": 720,
      "retarget_padding": 16,
      "body_stick_width": -1,
      "hand_stick_width": -1,
      "draw_head": true
    }
  },

  "24": {
    "class_type": "WanVideoAnimateEmbeds",
    "_meta": { "title": "Wan Animate Embeds (pose + face + ref + clip)" },
    "inputs": {
      "vae": ["2", 0],
      "clip_embeds": ["7", 0],
      "ref_images": ["6", 0],
      "pose_images": ["23", 0],
      "face_images": ["22", 1],
      "width": 1280,
      "height": 720,
      "num_frames": 81,
      "force_offload": true,
      "frame_window_size": 77,
      "colormatch": "disabled",
      "pose_strength": 1.0,
      "face_strength": 1.0
    }
  },

  "31": {
    "class_type": "WanVideoContextOptions",
    "_meta": { "title": "Context Options (long-gen; wired by stage4 ENABLE_CONTEXT=1)" },
    "inputs": {
      "context_schedule": "static_standard",
      "context_frames": 81,
      "context_stride": 4,
      "context_overlap": 32,
      "freenoise": true,
      "verbose": false,
      "fuse_method": "linear"
    }
  },

  "30": {
    "class_type": "WanVideoSampler",
    "_meta": { "title": "Wan Animate Sampler (lightx2v distill, 6 steps)" },
    "inputs": {
      "model": ["14", 0],
      "image_embeds": ["24", 0],
      "text_embeds": ["10", 0],
      "steps": 6,
      "cfg": 1.0,
      "shift": 5.0,
      "seed": 42,
      "force_offload": true,
      "scheduler": "dpm++_sde",
      "riflex_freq_index": 0
    }
  },

  "40": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["2", 0],
      "samples": ["30", 0],
      "enable_vae_tiling": false,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    }
  },
  "45": {
    "class_type": "RIFE VFI",
    "_meta": { "title": "RIFE Frame Interpolation" },
    "inputs": {
      "frames": ["40", 0],
      "ckpt_name": "rife47.pth",
      "clear_cache_after_n_frames": 10,
      "multiplier": 2,
      "fast_mode": true,
      "ensemble": true,
      "scale_factor": 1.0,
      "dtype": "float32",
      "torch_compile": false,
      "batch_size": 1
    }
  },
  "50": {
    "class_type": "VHS_VideoCombine",
    "_meta": { "title": "Final Video Output" },
    "inputs": {
      "images": ["45", 0],
      "frame_rate": 24,
      "loop_count": 0,
      "filename_prefix": "qi_render",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    }
  }
}
