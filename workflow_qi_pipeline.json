{
  "1": {
    "class_type": "WanVideoModelLoader",
    "inputs": {
      "model": "wan2.1_fun_control_14B_fp8.safetensors",
      "base_precision": "bf16",
      "quantization": "disabled",
      "load_device": "offload_device",
      "attention_mode": "sdpa"
    }
  },
  "2": {
    "class_type": "LoadWanVideoT5TextEncoder",
    "inputs": {
      "model_name": "umt5-xxl-enc-fp8_e4m3fn.safetensors",
      "precision": "bf16",
      "load_device": "offload_device",
      "quantization": "disabled"
    }
  },
  "3": {
    "class_type": "WanVideoVAELoader",
    "inputs": {
      "model_name": "wan_2.1_vae.safetensors",
      "precision": "bf16"
    }
  },
  "4": {
    "class_type": "CLIPVisionLoader",
    "inputs": {
      "clip_name": "clip_vision_h.safetensors"
    }
  },
  "5": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "/opt/qi-pipeline/input/reference_image.png"
    }
  },
  "6": {
    "class_type": "ImageScale",
    "inputs": {
      "image": ["5", 0],
      "width": 832,
      "height": 480,
      "upscale_method": "lanczos",
      "crop": "disabled"
    }
  },
  "7": {
    "class_type": "WanVideoClipVisionEncode",
    "inputs": {
      "clip_vision": ["4", 0],
      "image_1": ["6", 0],
      "strength_1": 1.0,
      "strength_2": 1.0,
      "force_offload": true,
      "crop": "center",
      "combine_embeds": "average"
    }
  },
  "10": {
    "class_type": "WanVideoTextEncode",
    "_meta": { "title": "Positive & Negative Prompts" },
    "inputs": {
      "positive_prompt": "Cinematic 8k video, medium wide shot, a athletic practitioner performing sacred Tai Chi movements. Photorealistic bare skin texture with visible muscle definition, subtle skin pores, and natural body contours. Golden volumetric lighting cuts through a clean, minimalist studio background, catching the precise edge of the turning torso. Swirling bioluminescent particles of liquid light and auric currents flow smoothly along the pathways of the meridians and up the spine, pulsing with every slow kinetic transition. The energetic trails wrap seamlessly around the moving boundaries of the body, shifting from a warm glowing amber at the lower dantian base into an ethereal radiant white as it ascends the spinal column. Flowing motion, highly detailed anatomy, hyper-realistic physics, clean framing, shallow depth of field, filmic quality.",
      "negative_prompt": "text, watermark, logo, deformed limbs, floating joints, extra fingers, clothing, underwear, fabrics, swimming trunks, rubbery skin, sudden morphing, rapid camera cuts, motion blur artifacts, flat lighting, background noise, low resolution, plastic texture, cartoon, 3D render artifact.",
      "t5": ["2", 0],
      "model_to_offload": ["1", 0],
      "force_offload": true,
      "use_disk_cache": false,
      "device": "gpu"
    }
  },
  "20": {
    "class_type": "VHS_LoadImages",
    "_meta": { "title": "DensePose Guidance Frames" },
    "inputs": {
      "directory": "/opt/qi-pipeline/output/controlnet_maps/composite",
      "image_load_cap": 0,
      "skip_first_images": 0,
      "select_every_nth": 1
    }
  },
  "21": {
    "class_type": "ImageScale",
    "inputs": {
      "image": ["20", 0],
      "width": 832,
      "height": 480,
      "upscale_method": "lanczos",
      "crop": "disabled"
    }
  },
  "22": {
    "class_type": "WanVideoEncode",
    "inputs": {
      "vae": ["3", 0],
      "image": ["21", 0],
      "enable_vae_tiling": false,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128,
      "noise_aug_strength": 0.0,
      "latent_strength": 1.0
    }
  },
  "23": {
    "class_type": "WanVideoControlEmbeds",
    "inputs": {
      "latents": ["22", 0],
      "start_percent": 0.0,
      "end_percent": 1.0
    }
  },
  "24": {
    "class_type": "WanVideoImageToVideoEncode",
    "inputs": {
      "vae": ["3", 0],
      "clip_embeds": ["7", 0],
      "start_image": ["6", 0],
      "width": 832,
      "height": 480,
      "num_frames": 35,
      "noise_aug_strength": 0.03,
      "start_latent_strength": 1.0,
      "end_latent_strength": 1.0,
      "force_offload": true,
      "control_embeds": ["23", 0],
      "fun_or_fl2v_model": true
    }
  },
  "30": {
    "class_type": "WanVideoSampler",
    "_meta": { "title": "Wan 2.1 Fun Control Sampler" },
    "inputs": {
      "model": ["1", 0],
      "text_embeds": ["10", 0],
      "image_embeds": ["24", 0],
      "steps": 30,
      "cfg": 5.5,
      "shift": 5.0,
      "seed": 42,
      "force_offload": true,
      "scheduler": "unipc",
      "riflex_freq_index": 0
    }
  },
  "40": {
    "class_type": "WanVideoDecode",
    "inputs": {
      "vae": ["3", 0],
      "samples": ["30", 0],
      "enable_vae_tiling": false,
      "tile_x": 272,
      "tile_y": 272,
      "tile_stride_x": 144,
      "tile_stride_y": 128
    }
  },
  "45": {
    "class_type": "RIFE VFI",
    "_meta": { "title": "RIFE Frame Interpolation" },
    "inputs": {
      "frames": ["40", 0],
      "ckpt_name": "rife47.pth",
      "clear_cache_after_n_frames": 10,
      "multiplier": 2,
      "fast_mode": true,
      "ensemble": true,
      "scale_factor": 1.0
    }
  },
  "50": {
    "class_type": "VHS_VideoCombine",
    "_meta": { "title": "Final Video Output" },
    "inputs": {
      "images": ["45", 0],
      "frame_rate": 24,
      "loop_count": 0,
      "filename_prefix": "qi_render",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    }
  }
}
